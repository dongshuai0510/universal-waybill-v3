# ============ V3 运单全流程管理系统 · 环境变量 ============

# ---- 数据库（V3 独立实例，不与 V2 共库）----
# 不设置 DATABASE_URL 时，本地自动使用 SQLite（./data/v3.db），零配置跑通。
# 部署 Vercel 时通过 Neon Marketplace 注入（独立于 V2 的 Neon 实例）。
# DATABASE_URL=postgresql://user:password@host/v3db?sslmode=require

# ---- V2 接口对接 ----
# V2（万能导入）线上地址；V3 通过 HTTP 接口调用它做运单真实性校验。
V2_API_BASE=https://universal-import-v2-ten.vercel.app
# 调用 V2 集成接口的共享密钥，必须与 V2 侧的 V3_API_KEY 一致。
V2_API_KEY=v3-dev-shared-key
# 单次接口超时（毫秒）与重试次数
V2_API_TIMEOUT_MS=6000
V2_API_RETRIES=2

# ---- 大模型（可选加分项）----
# 未配置时使用内置启发式分类器（heuristic），不阻塞主流程。
# ANTHROPIC_API_KEY=sk-ant-xxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-opus-4-8

# ---- 定时任务鉴权（超时自动流转）----
# /api/cron/timeout 触发时校验，避免被随意调用。
CRON_SECRET=v3-cron-secret
